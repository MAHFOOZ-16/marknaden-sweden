# ═══════════════════════════════════════════
# Marketplace Environment Variables
# ═══════════════════════════════════════════

# App
DEBUG=true
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://marketplace:marketplace@localhost:5432/marketplace
DATABASE_URL_SYNC=postgresql://marketplace:marketplace@localhost:5432/marketplace

# Auth0 (replace with your credentials)
AUTH0_DOMAIN=dev-marketplace.us.auth0.com
AUTH0_API_AUDIENCE=https://api.marketplace.local
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH_MOCK_ENABLED=true

# Stripe (replace with your keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# S3 / Object Storage
S3_BUCKET_NAME=marketplace-media
S3_REGION=eu-north-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_AUTH0_DOMAIN=dev-marketplace.us.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_AUTH0_AUDIENCE=https://api.marketplace.local
